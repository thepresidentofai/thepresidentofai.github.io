---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Terms | Boho Digital" description="Plain-language terms for Boho Digital." image="/assets/backgrounds/cream-paper-texture.webp">
  <section class="page-hero">
    <div class="container prose-wrap">
      <div class="section-heading compact" data-reveal>
        <p class="eyebrow">Terms</p>
        <h1>Plain-language terms</h1>
        <p>
          This site shares general studio information and educational material. Specific
          project scope, deliverables, and timelines are confirmed through direct
          engagement.
        </p>
      </div>
      <div class="prose-body" data-reveal>
        <p>Nothing on the site promises guaranteed rankings, guaranteed revenue, or universal outcomes.</p>
        <p>Work is scoped based on the actual system in front of us and the access available.</p>
      </div>
    </div>
  </section>
</BaseLayout>

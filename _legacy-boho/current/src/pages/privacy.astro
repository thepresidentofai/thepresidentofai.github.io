---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Privacy | Boho Digital" description="Privacy notes for Boho Digital." image="/assets/backgrounds/cream-paper-texture.webp">
  <section class="page-hero">
    <div class="container prose-wrap">
      <div class="section-heading compact" data-reveal>
        <p class="eyebrow">Privacy</p>
        <h1>Privacy notes</h1>
        <p>
          This site is intentionally light. Contact inquiries are designed to open an
          email draft rather than push form data into an unseen backend.
        </p>
      </div>
      <div class="prose-body" data-reveal>
        <p>Boho keeps collection minimal, avoids fake lead traps, and prefers transparency over background theater.</p>
        <p>If future analytics or contact tooling changes, this page should change with it.</p>
      </div>
    </div>
  </section>
</BaseLayout>

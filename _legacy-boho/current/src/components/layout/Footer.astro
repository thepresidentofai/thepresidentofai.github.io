---
import LogoLockup from "../brand/LogoLockup.astro";
import { footerNav } from "../../data/nav";
import { SITE } from "../../data/site";
---
<footer class="footer-wrap">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <LogoLockup compact={true} />
        <p>
          {SITE.tagline} SEO, content ecosystems, website optimization, analytics, and
          provider-transfer support for brands that want clearer ownership and steadier
          momentum.
        </p>
        <div class="footer-meta">
          <span>Email: {SITE.email}</span>
          <span>Location: {SITE.location}</span>
          <span>Astro-generated, documentation-forward</span>
        </div>
      </div>
      <div class="footer-links" aria-label="Footer">
        {footerNav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    </div>
    <p class="footer-small">&copy; 2026 {SITE.name}. All rights reserved.</p>
    <p class="footer-legal">
      Built for ownership clarity, organic growth, accessible explanations, lean
      website practices, and responsible migrations.
    </p>
  </div>
</footer>

---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  type?: "button" | "submit" | "reset";
  className?: string;
}

const {
  href,
  variant = "primary",
  type = "button",
  className = ""
} = Astro.props;
---
{href ? (
  <a class:list={["button", `button-${variant}`, className]} href={href}>
    <slot />
  </a>
) : (
  <button class:list={["button", `button-${variant}`, className]} type={type}>
    <slot />
  </button>
)}

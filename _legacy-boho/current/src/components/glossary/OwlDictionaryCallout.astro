---
import AskTheOwlCard from "../ui/AskTheOwlCard.astro";
import Button from "../ui/Button.astro";
---
<AskTheOwlCard
  title="Bring definitions into the page itself."
  body="Important terms should help, not interrupt. Use the dictionary preview, then follow the thread into full entries when you want the longer version."
>
  <div class="stack-actions">
    <Button href="/ask-the-owl/dictionary/">Open the Dictionary</Button>
    <Button href="/ask-the-owl/" variant="secondary">Visit Ask the Owl</Button>
  </div>
</AskTheOwlCard>

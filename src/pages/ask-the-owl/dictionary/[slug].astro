---
import Layout from "~/layouts/PageLayout.astro";
import HeroText from "~/components/widgets/HeroText.astro";
import CallToAction from "~/components/widgets/CallToAction.astro";
import WidgetWrapper from "~/components/ui/WidgetWrapper.astro";
import Headline from "~/components/ui/Headline.astro";
import Button from "~/components/ui/Button.astro";
import RelatedDictionaryTerms from "~/components/glossary/RelatedDictionaryTerms.astro";
import { dictionaryEntries, type DictionaryEntry } from "~/data/dictionary";
import { getServiceCardBySlug } from "~/data/boho";

interface Props {
  entry: DictionaryEntry;
}

export function getStaticPaths() {
  return dictionaryEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const metadata = {
  title: `${entry.term} | Owl Dictionary`,
  description: entry.shortDefinition,
};

const relatedServices = entry.relatedServices
  .map((slug) => getServiceCardBySlug(slug))
  .filter(Boolean);
---

<Layout metadata={metadata}>
  <HeroText
    tagline={entry.category}
    title={entry.term}
    subtitle={entry.shortDefinition}
  />

  <WidgetWrapper>
    <div class="mx-auto max-w-4xl space-y-10">
      <section
        class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm"
      >
        <h2 class="text-2xl font-bold text-charcoal">Short definition</h2>
        <p class="mt-4 text-lg text-muted">{entry.shortDefinition}</p>
      </section>

      <section
        class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm"
      >
        <h2 class="text-2xl font-bold text-charcoal">Plain-English version</h2>
        <p class="mt-4 text-lg text-muted">{entry.plainEnglish}</p>
      </section>

      <section
        class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm"
      >
        <h2 class="text-2xl font-bold text-charcoal">Why it matters</h2>
        <p class="mt-4 text-lg text-muted">{entry.whyItMatters}</p>
      </section>

      <section
        class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm"
      >
        <h2 class="text-2xl font-bold text-charcoal">What to watch for</h2>
        <p class="mt-4 text-lg text-muted">{entry.watchFor}</p>
      </section>

      <section
        class="rounded-3xl border border-terracotta/20 bg-white/90 p-6 shadow-sm shadow-terracotta/5"
      >
        <h2 class="text-2xl font-bold text-charcoal">Ask this before buying</h2>
        <p class="mt-4 text-lg text-muted">{entry.askThis}</p>
      </section>
    </div>
  </WidgetWrapper>

  <WidgetWrapper>
    <Headline
      title="Related services"
      subtitle="These are the Boho service paths most likely to touch this term."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        relatedServices.map((service) => (
          <a
            class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm transition hover:-translate-y-0.5"
            href={service?.href ?? "/services/"}
          >
            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
              Related service
            </p>
            <h3 class="mt-3 text-xl font-bold text-charcoal">
              {service?.title}
            </h3>
            <p class="mt-3 text-muted">{service?.description}</p>
          </a>
        ))
      }
      {
        relatedServices.length === 0 && (
          <div class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm">
            <p class="text-muted">
              This term is mostly educational. Start with the full services
              overview when you need a project path.
            </p>
            <div class="mt-5">
              <Button href="/services/">Explore Services</Button>
            </div>
          </div>
        )
      }
    </div>
  </WidgetWrapper>

  <WidgetWrapper>
    <Headline
      title="Related Owl terms"
      subtitle="Follow the connected language when the next question needs a little more context."
    />
    <div class="mt-10">
      <RelatedDictionaryTerms slugs={entry.relatedTerms} />
    </div>
  </WidgetWrapper>

  <CallToAction
    title="Need the term translated into a next step?"
    subtitle="Send the site, report, provider claim, or confusing dashboard. Boho can help turn the language into a practical decision."
    actions={[
      {
        variant: "primary",
        text: "Start the conversation",
        href: "/contact/",
      },
    ]}
  />
</Layout>

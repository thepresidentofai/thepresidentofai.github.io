---
import Layout from "~/layouts/PageLayout.astro";
import HeroText from "~/components/widgets/HeroText.astro";
import WidgetWrapper from "~/components/ui/WidgetWrapper.astro";
import Headline from "~/components/ui/Headline.astro";
import Button from "~/components/ui/Button.astro";
import { dictionaryTerms } from "~/data/boho";

const metadata = {
  title: "Dictionary",
  description:
    "A simple categorized list of Boho Digital dictionary terms for SEO, content, analytics, provider transfers, AI, and digital footprint questions.",
};

const categories = Array.from(
  new Set(dictionaryTerms.map((term) => term.category)),
);

const toAnchorId = (term: string) =>
  term
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Dictionary"
    title="The Owl Dictionary."
    subtitle="A simple categorized list. No hover popovers, no inline definitions, and no extra theater."
  />

  <WidgetWrapper>
    <Headline
      title="Seed terms"
      subtitle="Start with the plain-English definition, then open a related page if it exists."
    />

    <div class="mt-10 space-y-12">
      {
        categories.map((category) => (
          <section>
            <div class="mb-5">
              <h2 class="text-2xl font-bold text-charcoal">{category}</h2>
            </div>
            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
              {dictionaryTerms
                .filter((term) => term.category === category)
                .map((term) => (
                  <article
                    id={toAnchorId(term.term)}
                    class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm"
                  >
                    <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
                      {term.category}
                    </p>
                    <h3 class="mt-3 text-2xl font-bold text-charcoal">
                      {term.term}
                    </h3>
                    <p class="mt-3 text-muted">{term.definition}</p>
                    {term.href && (
                      <div class="mt-4">
                        <Button href={term.href} variant="secondary">
                          Read more
                        </Button>
                      </div>
                    )}
                  </article>
                ))}
            </div>
          </section>
        ))
      }
    </div>
  </WidgetWrapper>
</Layout>

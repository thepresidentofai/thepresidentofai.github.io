---
import Layout from "~/layouts/PageLayout.astro";
import HeroText from "~/components/widgets/HeroText.astro";
import WidgetWrapper from "~/components/ui/WidgetWrapper.astro";
import Headline from "~/components/ui/Headline.astro";
import DictionaryCard from "~/components/glossary/DictionaryCard.astro";
import { dictionaryCategories, dictionaryEntries } from "~/data/dictionary";

const metadata = {
  title: "Dictionary",
  description:
    "The Boho Digital Owl Dictionary for plain-English SEO, content, analytics, provider-transfer, AI, bad SEO, performance, and sustainability terms.",
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Owl Dictionary"
    title="The glossary for people who have things to do."
    subtitle="Short definitions, useful context, and links into the real work. No jargon fog, no agency theater, and no scavenger hunt through a 40-page PDF someone called a strategy."
  />

  <WidgetWrapper>
    <Headline
      title="Start with the term, then follow the work."
      subtitle="The Owl Dictionary explains the terms that show up around SEO, content, analytics, provider transfers, AI workflows, and bad SEO warning signs. Start with the short definition, then open the full entry when the term affects a decision."
    />

    <div class="mb-10 flex flex-wrap justify-center gap-3">
      {
        dictionaryCategories.map((category) => (
          <a
            class="rounded-full border border-moss/20 bg-white/80 px-4 py-2 text-sm font-semibold text-moss-dark transition hover:border-honey hover:bg-warm-bone"
            href={`#${category
              .toLowerCase()
              .replace(/&/g, "and")
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/^-+|-+$/g, "")}`}
          >
            {category}
          </a>
        ))
      }
    </div>

    <div class="space-y-14">
      {
        dictionaryCategories.map((category) => (
          <section
            id={category
              .toLowerCase()
              .replace(/&/g, "and")
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/^-+|-+$/g, "")}
          >
            <div class="mb-6">
              <h2 class="text-2xl font-bold text-charcoal">{category}</h2>
            </div>
            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
              {dictionaryEntries
                .filter((entry) => entry.category === category)
                .map((entry) => (
                  <DictionaryCard entry={entry} />
                ))}
            </div>
          </section>
        ))
      }
    </div>
  </WidgetWrapper>
</Layout>

---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Ask the Owl',
  description: 'Plain-English answers for SEO, content, analytics, AI, provider transfers, and sustainable digital growth.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Ask the Owl"
    title="Ask the Owl."
    subtitle="Plain-English answers for SEO, content, analytics, AI, provider transfers, and sustainable digital growth."
    callToAction={{ text: 'Open the Dictionary', href: '/ask-the-owl/dictionary/' }}
    callToAction2={{ text: 'Ask a scope question', href: '/contact/' }}
  />

  <Features2
    title="Start with the category that matches the problem."
    columns={3}
    items={[
      { title: 'SEO Basics', description: 'Core search language that shapes visibility, structure, and technical trust.', icon: 'tabler:search' },
      { title: 'Content Strategy', description: 'Clusters, search intent, and content relationships that support the whole forest.', icon: 'tabler:books' },
      { title: 'Analytics & Reporting', description: 'Measurement language that clarifies what moved and what should change next.', icon: 'tabler:chart-histogram' },
      { title: 'Provider Transfers', description: 'DNS, hosting, redirects, analytics continuity, and ownership language for messy moves.', icon: 'tabler:route-square-2' },
      { title: 'AI & Digital Tools', description: 'Operational uses of AI that reduce drag without replacing judgment.', icon: 'tabler:cpu-2' },
      { title: 'Bad SEO / Fox Traps', description: 'The phrases and tactics that look helpful right before they get expensive.', icon: 'tabler:alert-triangle' },
      { title: 'Climate & Digital Footprint', description: 'Leaner patterns, quieter operations, and impact language that stays honest.', icon: 'tabler:leaf' },
    ]}
  />

  <Content
    tagline="How to use it"
    title="Translation first. Bigger decisions second."
    items={[
      {
        title: 'Read the short version first',
        description: 'Start with the one-sentence definition when you only need a cleaner mental model.',
      },
      {
        title: 'Follow the term into the real work',
        description: 'The point is not to memorize jargon. It is to make audits, transfers, and strategy conversations easier to navigate.',
      },
      {
        title: 'Ask when the stack still feels muddy',
        description: 'If the term makes more sense but the project does not, bring the real situation into a scope conversation.',
      },
    ]}
    image={{ src: '/assets/mascots/owl-dictionary.svg', alt: 'Owl icon representing Ask the Owl guidance' }}
  />

  <CallToAction
    title="Need the definitions translated into action?"
    subtitle="The dictionary is there to make the language easier. The next step is choosing the right audit, cleanup pass, or provider-transfer plan."
    actions={[
      {
        variant: 'primary',
        text: 'Open the Dictionary',
        href: '/ask-the-owl/dictionary/',
      },
      {
        text: 'Review Services',
        href: '/services/',
      },
    ]}
  />
</Layout>

---
import Layout from "~/layouts/PageLayout.astro";
import HeroText from "~/components/widgets/HeroText.astro";
import Features2 from "~/components/widgets/Features2.astro";
import CallToAction from "~/components/widgets/CallToAction.astro";
import WidgetWrapper from "~/components/ui/WidgetWrapper.astro";
import Headline from "~/components/ui/Headline.astro";

const metadata = {
  title: "Ask the Owl",
  description:
    "Plain-English answers for SEO, analytics, provider-transfer, AI, and bad-agency jargon.",
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Ask the Owl"
    title="Plain-English answers before the agency fog rolls in."
    subtitle="Ask the Owl translates SEO, analytics, provider-transfer, AI, and bad-agency jargon into language a business owner can actually use."
    callToAction={{
      text: "Open the Dictionary",
      href: "/ask-the-owl/dictionary/",
    }}
    callToAction2={{ text: "Ask a scope question", href: "/contact/" }}
  />

  <WidgetWrapper>
    <Headline
      title="Use enough language to ask sharper questions."
      subtitle="You do not need to memorize every acronym to make better decisions. You need enough language to ask sharper questions, understand what is at risk, and spot when a vendor is using complexity as camouflage."
    />
  </WidgetWrapper>

  <Features2
    title="Start with the category that matches the problem."
    columns={3}
    items={[
      {
        title: "SEO Basics",
        description:
          "The search language behind keywords, intent, rankings, clicks, and visibility.",
        icon: "tabler:search",
        callToAction: {
          text: "Open terms",
          href: "/ask-the-owl/dictionary/#seo-basics",
        },
      },
      {
        title: "Technical SEO",
        description:
          "Crawlability, indexing, metadata, redirects, canonicals, sitemaps, and the mechanics search engines have to process.",
        icon: "tabler:settings-search",
        callToAction: {
          text: "Open terms",
          href: "/ask-the-owl/dictionary/#technical-seo",
        },
      },
      {
        title: "Content Strategy",
        description:
          "Service pages, content clusters, internal links, helpful content, and the difference between useful depth and blog sprawl.",
        icon: "tabler:books",
        callToAction: {
          text: "Open terms",
          href: "/ask-the-owl/dictionary/#content-strategy",
        },
      },
      {
        title: "Local SEO",
        description:
          "Google Business Profile, citations, reviews, service areas, and the local signals customers actually see.",
        icon: "tabler:map-pin",
        callToAction: {
          text: "Open terms",
          href: "/ask-the-owl/dictionary/#local-seo",
        },
      },
      {
        title: "Analytics & Reporting",
        description:
          "Search Console, GA4, conversions, KPIs, vanity metrics, and reports that should lead to decisions.",
        icon: "tabler:chart-histogram",
        callToAction: {
          text: "Open terms",
          href: "/ask-the-owl/dictionary/#analytics-and-reporting",
        },
      },
      {
        title: "Provider Transfers",
        description:
          "DNS, hosting, domains, redirects, ownership trails, and the boring details that become expensive when ignored.",
        icon: "tabler:route-square-2",
        callToAction: {
          text: "Open terms",
          href: "/ask-the-owl/dictionary/#provider-transfers",
        },
      },
      {
        title: "AI & Digital Tools",
        description:
          "AI workflows, prompt libraries, review loops, and the guardrails that keep automation from producing sludge.",
        icon: "tabler:cpu-2",
        callToAction: {
          text: "Open terms",
          href: "/ask-the-owl/dictionary/#ai-and-digital-tools",
        },
      },
      {
        title: "Bad SEO / Fox Traps",
        description:
          "Guaranteed rankings, link farms, black-box SEO, fake local pages, reporting theater, and other budget traps.",
        icon: "tabler:alert-triangle",
        callToAction: {
          text: "Open terms",
          href: "/ask-the-owl/dictionary/#bad-seo-fox-traps",
        },
      },
      {
        title: "Performance & Sustainability",
        description:
          "Page weight, Core Web Vitals, leaner workflows, and careful impact language.",
        icon: "tabler:leaf",
        callToAction: {
          text: "Open terms",
          href: "/ask-the-owl/dictionary/#performance-and-sustainability",
        },
      },
    ]}
  />

  <CallToAction
    title="Need the definitions translated into action?"
    subtitle="The dictionary is there to make the language easier. The next step is choosing the right audit, cleanup pass, or provider-transfer plan."
    actions={[
      {
        variant: "primary",
        text: "Open the Dictionary",
        href: "/ask-the-owl/dictionary/",
      },
      {
        text: "Review Services",
        href: "/services/",
      },
    ]}
  />
</Layout>

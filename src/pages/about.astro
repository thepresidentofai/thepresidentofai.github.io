---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';

const metadata = {
  title: 'About',
  description: 'Boho Digital is a forest-inspired SEO and digital marketing studio built around clarity, documentation, and better ownership.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="About"
    title="A modern forest studio for growth work that stays readable."
    subtitle="Boho Digital combines SEO, content, website optimization, analytics, and provider-transfer support with a bias toward ownership clarity and durable documentation."
  />

  <Features2
    title="What matters here"
    columns={3}
    items={[
      {
        title: 'Readable strategy',
        description: 'Translate complex systems into plain-English next steps instead of agency fog.',
        icon: 'tabler:notes',
      },
      {
        title: 'Ownership clarity',
        description: 'Leave a trail the next person can actually follow after the work is done.',
        icon: 'tabler:key',
      },
      {
        title: 'Careful language',
        description: 'Stay disciplined around AI, climate claims, and what the evidence can actually support.',
        icon: 'tabler:leaf',
      },
    ]}
  />

  <Content
    tagline="Practice"
    title="Smaller useful systems, built to last longer than the launch glow."
    items={[
      {
        title: 'Search systems',
        description: 'Search, content, reporting, and ownership are part of the same environment, not disconnected chores.',
      },
      {
        title: 'Documentation',
        description: 'Good work should remain understandable after launch, handoff, and inevitable future change.',
      },
      {
        title: 'Steady stewardship',
        description: 'Boho favors calmer rhythms, practical prioritization, and less theatrical digital clutter.',
      },
    ]}
    image={{ src: '/assets/backgrounds/forest-mist.webp', alt: 'Forest mist representing quiet stewardship' }}
  />
</Layout>

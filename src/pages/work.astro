---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Work',
  description:
    'Every project leaves a trail. Boho documents audits, migrations, reporting, and implementation notes instead of hiding the work.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Work"
    title="Every project leaves a trail."
    subtitle="Boho does not manufacture fake case studies or glossy praise wallpaper. The real value is in the documents: what was found, what changed, what moved, and what the next person needs to know."
  />

  <Features2
    title="What the trail usually includes"
    columns={2}
    items={[
      {
        title: 'Audit roadmaps',
        description: 'Sequencing, visibility blockers, content structure, and the next useful decisions.',
        icon: 'tabler:route',
      },
      {
        title: 'Migration maps',
        description: 'Access recovery, redirects, DNS coordination, analytics continuity, and post-launch QA.',
        icon: 'tabler:map-2',
      },
      {
        title: 'Implementation records',
        description: 'Changes, checks, and handoff notes that survive the project instead of disappearing into chat.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Owner-facing summaries',
        description: 'Language that explains what the system is doing without hiding behind jargon or theater.',
        icon: 'tabler:file-analytics',
      },
    ]}
  />

  <Content
    tagline="What you will not find here"
    title="No invented praise. No invented revenue numbers. No mystery theater."
    items={[
      {
        title: 'No performance cosplay',
        description: 'Boho will not pad a site with made-up customer praise or suspiciously glossy wins.',
      },
      {
        title: 'No silent black box',
        description: 'The work should make the next person more capable, not more dependent.',
      },
      {
        title: 'No fluff where evidence should be',
        description: 'Real artifacts matter more than decorative claims about what supposedly happened.',
      },
    ]}
    image={{ src: '/assets/backgrounds/moss-texture.webp', alt: 'Moss texture representing quiet documentation work' }}
  />

  <CallToAction
    title="Want to talk through a real project?"
    subtitle="Bring the context, the constraints, and the pieces that feel muddy. Boho can help map the next step."
    actions={[
      {
        variant: 'primary',
        text: 'Ask about a project',
        href: '/contact/',
      },
    ]}
  />
</Layout>

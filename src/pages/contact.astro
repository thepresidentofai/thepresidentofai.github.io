---
import Layout from "~/layouts/PageLayout.astro";
import HeroText from "~/components/widgets/HeroText.astro";
import WidgetWrapper from "~/components/ui/WidgetWrapper.astro";
import Headline from "~/components/ui/Headline.astro";
import Button from "~/components/ui/Button.astro";

const metadata = {
  title: "Contact",
  description:
    "Contact Boho Digital about SEO audits, technical cleanup, content strategy, local SEO, provider transfers, hosting moves, and monthly growth support.",
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Let's map the forest."
    subtitle="Tell us where your brand is trying to grow, or what provider mess you are trying to escape. We can help you choose the right first step."
  />

  <WidgetWrapper>
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="space-y-6">
        <Headline
          title="Bring the actual situation."
          subtitle="You do not need perfect documentation before reaching out. Send whatever you know and Boho can help identify the missing pieces."
          classes={{
            container: "text-left rtl:text-right max-w-none",
            title: "text-3xl md:text-4xl",
            subtitle: "text-lg text-muted",
          }}
        />
        <div
          class="rounded-3xl border border-moss/15 bg-white/85 p-6 shadow-sm"
        >
          <p
            class="text-sm font-semibold uppercase tracking-[0.12em] text-moss"
          >
            Switching providers?
          </p>
          <p class="mt-3 text-muted">
            Send the current website, SEO provider, hosting platform, domain
            registrar if known, analytics access if available, and what you are
            trying to change.
          </p>
        </div>
        <div
          class="rounded-3xl border border-moss/15 bg-white/85 p-6 shadow-sm"
        >
          <p
            class="text-sm font-semibold uppercase tracking-[0.12em] text-moss"
          >
            Need a translation first?
          </p>
          <p class="mt-3 text-muted">
            Ask the Owl is there for the terms that usually show up right before
            a project gets more confusing than it needs to be.
          </p>
          <div class="mt-4">
            <Button href="/ask-the-owl/dictionary/" variant="secondary"
              >Open the Dictionary</Button
            >
          </div>
        </div>
      </div>

      <form
        id="form"
        action="mailto:hello@bohodigitalservices.com"
        method="post"
        enctype="text/plain"
        class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-lg shadow-moss-black/5"
      >
        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <label
              for="name"
              class="mb-2 block text-sm font-medium text-charcoal">Name</label
            >
            <input
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              class="w-full rounded-2xl border border-moss/20 bg-cream px-4 py-3 text-charcoal"
            />
          </div>
          <div>
            <label
              for="email"
              class="mb-2 block text-sm font-medium text-charcoal">Email</label
            >
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              class="w-full rounded-2xl border border-moss/20 bg-cream px-4 py-3 text-charcoal"
            />
          </div>
          <div>
            <label
              for="business"
              class="mb-2 block text-sm font-medium text-charcoal"
              >Business name</label
            >
            <input
              id="business"
              name="business"
              type="text"
              autocomplete="organization"
              class="w-full rounded-2xl border border-moss/20 bg-cream px-4 py-3 text-charcoal"
            />
          </div>
          <div>
            <label
              for="website"
              class="mb-2 block text-sm font-medium text-charcoal"
              >Website URL</label
            >
            <input
              id="website"
              name="website"
              type="url"
              autocomplete="url"
              class="w-full rounded-2xl border border-moss/20 bg-cream px-4 py-3 text-charcoal"
            />
          </div>
          <div class="md:col-span-2">
            <label
              for="provider"
              class="mb-2 block text-sm font-medium text-charcoal"
              >Current SEO or hosting provider if relevant</label
            >
            <input
              id="provider"
              name="provider"
              type="text"
              class="w-full rounded-2xl border border-moss/20 bg-cream px-4 py-3 text-charcoal"
            />
          </div>
          <div>
            <label
              for="help"
              class="mb-2 block text-sm font-medium text-charcoal"
              >What do you need help with?</label
            >
            <select
              id="help"
              name="help"
              class="w-full rounded-2xl border border-moss/20 bg-cream px-4 py-3 text-charcoal"
            >
              <option>SEO Growth Audit</option>
              <option>Technical SEO Cleanup</option>
              <option>Content Ecosystem Buildout</option>
              <option>Local SEO Foundation</option>
              <option>Website Optimization</option>
              <option>Analytics & Reporting</option>
              <option>AI-Assisted Workflows</option>
              <option>SEO & Hosting Provider Transfer</option>
              <option>Monthly Growth Retainer</option>
              <option>Not sure yet</option>
            </select>
          </div>
          <div>
            <label
              for="budget"
              class="mb-2 block text-sm font-medium text-charcoal"
              >Budget range</label
            >
            <input
              id="budget"
              name="budget"
              type="text"
              class="w-full rounded-2xl border border-moss/20 bg-cream px-4 py-3 text-charcoal"
            />
          </div>
          <div>
            <label
              for="timeline"
              class="mb-2 block text-sm font-medium text-charcoal"
              >Timeline</label
            >
            <input
              id="timeline"
              name="timeline"
              type="text"
              class="w-full rounded-2xl border border-moss/20 bg-cream px-4 py-3 text-charcoal"
            />
          </div>
          <div class="md:col-span-2">
            <label
              for="message"
              class="mb-2 block text-sm font-medium text-charcoal"
              >Message</label
            >
            <textarea
              id="message"
              name="message"
              rows="6"
              class="w-full rounded-2xl border border-moss/20 bg-cream px-4 py-3 text-charcoal"
            ></textarea>
          </div>
        </div>
        <div
          class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
        >
          <p class="text-sm text-muted">
            No hidden backend here. This form opens an email draft in your mail
            client.
          </p>
          <Button type="submit" variant="primary">Open the email draft</Button>
        </div>
      </form>
    </div>
  </WidgetWrapper>
</Layout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import AskTheOwlCard from "../components/ui/AskTheOwlCard.astro";
---
<BaseLayout
  title="Contact | Boho Digital"
  description="Simple static-friendly inquiry for growth audits, SEO cleanup, provider transfers, reporting, and Boho Digital support."
  image="/assets/backgrounds/forest-mist.webp"
>
  <section class="page-hero section-forest image-backed">
    <div class="container page-hero-grid">
      <div class="hero-panel" data-reveal>
        <div class="breadcrumbs">
          <a href="/">Home</a>
          <span>/</span>
          <strong>Contact</strong>
        </div>
        <p class="eyebrow">Contact</p>
        <h1>Let's map the forest.</h1>
        <p class="hero-lead">Simple static-friendly inquiry.</p>
      </div>
      <aside class="hero-side-panel" data-reveal="left">
        <p class="micro-label">Switching providers?</p>
        <p>
          You do not need to have everything organized before contacting us. Send
          whatever you know: your current website, SEO provider, hosting platform,
          domain registrar if known, analytics access if available, and what you are
          trying to change. We will help identify the missing pieces.
        </p>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-stack">
        <article class="section-card" data-reveal>
          <p class="eyebrow">Reach out</p>
          <h2>Bring the actual situation.</h2>
          <p>
            Boho is most useful when the message includes the real context: what is
            stuck, what already exists, and what ownership or visibility problem you are
            trying to solve.
          </p>
        </article>
        <article class="section-card" data-reveal>
          <p class="eyebrow">Provider-transfer helper</p>
          <ul class="ledger-list">
            <li>Current website URL</li>
            <li>Current SEO provider, host, or platform if known</li>
            <li>Who holds domain, hosting, or analytics access</li>
            <li>What you are trying to move, fix, or preserve</li>
          </ul>
        </article>
        <AskTheOwlCard
          title="The Owl can help translate the jargon first."
          body="If the provider stack or SEO language feels dense, the dictionary is there to make the first conversation easier."
        >
          <div class="stack-actions">
            <Button href="/ask-the-owl/dictionary/" variant="secondary">Open the Dictionary</Button>
          </div>
        </AskTheOwlCard>
      </div>

      <form class="contact-form section-card" data-mailto-form data-reveal="left">
        <div class="form-grid">
          <label>
            <span>Name</span>
            <input name="Name" type="text" required />
          </label>
          <label>
            <span>Email</span>
            <input name="Email" type="email" required />
          </label>
          <label>
            <span>Business name</span>
            <input name="Business name" type="text" />
          </label>
          <label>
            <span>Website URL</span>
            <input name="Website URL" type="url" />
          </label>
          <label class="field-span">
            <span>Current SEO provider, hosting provider, or platform, if relevant</span>
            <input name="Current provider or platform" type="text" />
          </label>
          <label>
            <span>What do you need help with?</span>
            <select name="Help needed">
              <option>SEO Growth Audit</option>
              <option>Technical SEO Cleanup</option>
              <option>Content Strategy</option>
              <option>Local SEO</option>
              <option>Website Optimization</option>
              <option>Analytics &amp; Reporting</option>
              <option>AI-Assisted Workflows</option>
              <option>SEO / Hosting Provider Transfer</option>
              <option>Monthly Growth Retainer</option>
              <option>Not sure yet</option>
            </select>
          </label>
          <label>
            <span>Budget range</span>
            <input name="Budget range" type="text" placeholder="Optional" />
          </label>
          <label>
            <span>Timeline</span>
            <input name="Timeline" type="text" placeholder="Optional" />
          </label>
          <label class="field-span">
            <span>Anything else worth knowing?</span>
            <textarea name="Anything else worth knowing" rows="7"></textarea>
          </label>
        </div>
        <div class="card-actions">
          <Button type="submit">Open the email draft</Button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

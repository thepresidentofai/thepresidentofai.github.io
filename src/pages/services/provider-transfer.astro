---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import { providerTransferFaqs, providerTransferSteps } from '~/data/boho';

const metadata = {
  title: 'SEO & Hosting Provider Transfer',
  description: 'Switch providers without losing the trail. Boho Digital helps map transfers, preserve search value, and document the handoff.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="SEO & Hosting Provider Transfer"
    title="Switch providers without losing the trail."
    subtitle="Moving away from an old SEO agency, hosting provider, website platform, or messy vendor setup can be stressful. Boho Digital helps map the transfer, preserve search value, and clean up the handoff step by step."
    callToAction={{ text: 'Ask about a transfer', href: '/contact/' }}
    callToAction2={{ text: 'Open Ask the Owl', href: '/ask-the-owl/' }}
  />

  <Features2
    title="Why transfers get messy"
    columns={3}
    items={[
      {
        title: 'Ownership is unclear',
        description: 'Domains, hosting, analytics, and platforms may be controlled by the wrong account or the wrong vendor.',
        icon: 'tabler:key-off',
      },
      {
        title: 'Documentation is thin',
        description: 'DNS records, redirects, metadata rules, and launch dependencies are often undocumented.',
        icon: 'tabler:file-x',
      },
      {
        title: 'Fear replaces planning',
        description: 'People are often told the move will destroy SEO without getting a usable explanation of what is actually at risk.',
        icon: 'tabler:alert-triangle',
      },
    ]}
  />

  <Features2
    title="What we help transfer"
    columns={3}
    items={[
      { title: 'SEO agency setups and reporting layers', description: 'Recover the real accounts, reporting views, and search ownership trail.', icon: 'tabler:chart-line' },
      { title: 'Hosting accounts and platform migrations', description: 'Understand where the site lives now and what changes during the move.', icon: 'tabler:server-2' },
      { title: 'DNS and registrar changes', description: 'Document the routing layer before anyone touches the records panel.', icon: 'tabler:world-www' },
      { title: 'Analytics and Search Console continuity', description: 'Protect the visibility and measurement trail you still need after launch.', icon: 'tabler:chart-dots-3' },
      { title: 'Redirect planning and metadata review', description: 'Preserve valuable paths instead of losing them to avoidable URL drift.', icon: 'tabler:arrow-fork' },
      { title: 'Owner-facing handoff documentation', description: 'Leave the stack more legible after the move than before it.', icon: 'tabler:file-description' },
    ]}
  />

  <Steps
    tagline="Migration steps"
    title="Controlled movement beats brave chaos."
    items={providerTransferSteps}
  />

  <WidgetWrapper>
    <Headline
      title="Checklists and red flags"
      subtitle="Use normal cards, not mystery jargon, to keep the handoff readable."
    />
    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      <article class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">SEO preservation checklist</p>
        <ul class="mt-4 space-y-3 text-muted">
          <li>Current high-value URLs and top organic landing pages identified</li>
          <li>Redirect map drafted before launch</li>
          <li>Metadata and title logic reviewed</li>
          <li>Search Console access confirmed</li>
          <li>Sitemap and robots.txt reviewed before the move</li>
          <li>Post-launch crawl and indexing checks scheduled</li>
        </ul>
      </article>
      <article class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">Hosting transfer checklist</p>
        <ul class="mt-4 space-y-3 text-muted">
          <li>Domain registrar access identified</li>
          <li>DNS records documented before changes</li>
          <li>Hosting provider and platform access confirmed</li>
          <li>CMS or repository access reviewed</li>
          <li>Forms, email, and integrations noted</li>
          <li>Owner-facing documentation created after the move</li>
        </ul>
      </article>
      <article class="rounded-3xl border border-terracotta/20 bg-white/90 p-6 shadow-sm shadow-terracotta/5">
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-terracotta-dark">Provider red flags</p>
        <ul class="mt-4 space-y-3 text-muted">
          <li>Your provider owns your domain.</li>
          <li>You do not have Search Console access.</li>
          <li>You cannot see analytics.</li>
          <li>You do not know where your site is hosted.</li>
          <li>Your provider refuses to document changes.</li>
          <li>Your provider says leaving will destroy SEO without explaining why.</li>
        </ul>
      </article>
    </div>
  </WidgetWrapper>

  <FAQs title="FAQs" columns={1} items={providerTransferFaqs} />

  <CallToAction
    title="Bring the messy stack. We'll help map the handoff."
    subtitle="You do not need perfect documentation before reaching out. Send what you know and Boho will help identify the missing pieces."
    actions={[
      {
        variant: 'primary',
        text: 'Start the transfer conversation',
        href: '/contact/',
      },
    ]}
  />
</Layout>

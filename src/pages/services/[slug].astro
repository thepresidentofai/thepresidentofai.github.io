---
import ServicePage from "~/components/boho/ServicePage.astro";
import { servicePageDetails } from "~/data/boho";

export function getStaticPaths() {
  return servicePageDetails.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<ServicePage page={page} />

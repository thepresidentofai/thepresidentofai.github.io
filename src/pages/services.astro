---
import Layout from "~/layouts/PageLayout.astro";
import HeroText from "~/components/widgets/HeroText.astro";
import Features2 from "~/components/widgets/Features2.astro";
import Content from "~/components/widgets/Content.astro";
import CallToAction from "~/components/widgets/CallToAction.astro";
import WidgetWrapper from "~/components/ui/WidgetWrapper.astro";
import Headline from "~/components/ui/Headline.astro";
import Button from "~/components/ui/Button.astro";
import { serviceCards, serviceChooserCards } from "~/data/boho";

const metadata = {
  title: "Services",
  description:
    "Dedicated Boho Digital service pages for SEO audits, technical cleanup, content systems, local SEO, reporting, provider transfers, and ongoing growth support.",
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Services"
    title="SEO, content, and web strategy built like an ecosystem."
    subtitle="Boho combines technical structure, content depth, analytics, provider-transfer support, and thoughtful optimization to help brands grow organically and measurably."
    callToAction={{ text: "Get a Growth Audit", href: "/contact/" }}
    callToAction2={{
      text: "Ask about Provider Transfer",
      href: "/services/provider-transfer/",
    }}
  />

  <Features2
    title="Readable service cards, not mystery packages."
    subtitle="Start with the smallest useful system that still strengthens the whole forest."
    columns={3}
    items={serviceCards.map((service) => ({
      ...service,
      callToAction: service.href
        ? {
            text: "Learn more",
            href: service.href,
          }
        : undefined,
    }))}
  />

  <WidgetWrapper>
    <Headline
      tagline="How to choose"
      title="Start with the problem you can actually see."
      subtitle="You do not need to diagnose the whole forest before taking a first step."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        serviceChooserCards.map((card) => (
          <article class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
              {card.title}
            </p>
            <p class="mt-3 text-muted">{card.description}</p>
            <div class="mt-5">
              <Button href={card.href}>See the service</Button>
            </div>
          </article>
        ))
      }
    </div>
  </WidgetWrapper>

  <Content
    tagline="Provider transfer callout"
    title="Switch providers without losing the trail."
    subtitle="Provider-transfer support exists because growth work gets fragile when nobody can explain who owns the domain, hosting, analytics, or redirects."
    items={[
      {
        title: "Inventory the stack",
        description:
          "Find the accounts, vendors, and access layers that matter before they become launch-day surprises.",
      },
      {
        title: "Preserve search value",
        description:
          "Protect URLs, metadata, analytics continuity, and the parts of the site already doing useful work.",
      },
      {
        title: "Leave better records",
        description:
          "Owner-facing documentation should be clearer after the move than before it.",
      },
    ]}
    callToAction={{
      text: "See Provider Transfer Support",
      href: "/services/provider-transfer/",
    }}
    image={{
      src: "/assets/backgrounds/moss-texture.webp",
      alt: "Moss texture representing patient structural work",
    }}
  />

  <CallToAction
    title="Not sure which service is the right first step?"
    subtitle="Bring the real situation. Boho can help you figure out whether the next move is an audit, cleanup pass, transfer plan, or ongoing support."
    actions={[
      {
        variant: "primary",
        text: "Start the conversation",
        href: "/contact/",
      },
    ]}
  />
</Layout>

---
import Layout from "~/layouts/PageLayout.astro";
import HomeHero from "~/components/home/HomeHero.astro";
import LeanTechStrip from "~/components/home/LeanTechStrip.astro";
import EntryPaths from "~/components/home/EntryPaths.astro";
import MonthlySupportFeature from "~/components/home/MonthlySupportFeature.astro";
import RushSupportFeature from "~/components/home/RushSupportFeature.astro";
import HiveProcess from "~/components/home/HiveProcess.astro";
import KnowledgeTrustSplit from "~/components/home/KnowledgeTrustSplit.astro";
import HomeFinalCTA from "~/components/home/HomeFinalCTA.astro";

const metadata = {
  title: "Boho Digital",
  ignoreTitleTemplate: true,
  description:
    "A lean, tech-enabled growth studio for SEO, websites, analytics, monthly support, provider transfers, and urgent digital cleanup.",
};
---

<Layout metadata={metadata}>
  <HomeHero />
  <LeanTechStrip />
  <EntryPaths />
  <MonthlySupportFeature />
  <RushSupportFeature />
  <HiveProcess />
  <KnowledgeTrustSplit />
  <HomeFinalCTA />
</Layout>

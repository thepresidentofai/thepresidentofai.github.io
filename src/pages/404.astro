---
import Layout from "~/layouts/PageLayout.astro";
import HeroText from "~/components/widgets/HeroText.astro";

const metadata = {
  title: "404",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="404"
    title="That trail is not here."
    subtitle="The page may have moved, the link may be wrong, or the route may still belong in the older forest map."
    callToAction={{ text: "Go home", href: "/" }}
    callToAction2={{ text: "See Services", href: "/services/" }}
  />
</Layout>

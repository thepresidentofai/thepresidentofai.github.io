---
const owlTerms = [
  "Technical SEO",
  "Search intent",
  "Redirect map",
  "Provider lock-in",
  "Google Search Console",
  "Vanity metrics",
];
const foxTraps = [
  "Guaranteed rankings",
  "Link farms",
  "Black-box SEO",
  "Provider lock-in",
  "Reporting theater",
];
---

<section class="bg-cream text-charcoal">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24">
    <div class="max-w-3xl">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-moss">
        Knowledge layer
      </p>
      <h2
        class="mt-3 text-4xl font-black tracking-normal text-charcoal md:text-5xl"
      >
        Clear language on one side. Fox traps on the other.
      </h2>
    </div>
    <div class="mt-10 grid gap-4 lg:grid-cols-2">
      <article class="rounded-lg border border-moss/15 bg-white p-6 shadow-sm">
        <p class="text-sm font-extrabold uppercase tracking-[0.16em] text-moss">
          Ask the Owl
        </p>
        <h3 class="mt-3 text-3xl font-black text-charcoal">Ask the Owl</h3>
        <p class="mt-4 text-base leading-7 text-muted">
          Plain-English definitions for the terms that show up in SEO audits,
          provider transfers, analytics reports, and AI workflows.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {
            owlTerms.map((term) => (
              <span class="rounded-full border border-moss/15 bg-warm-bone px-3 py-1.5 text-sm font-semibold text-moss-dark">
                {term}
              </span>
            ))
          }
        </div>
        <a
          class="mt-7 inline-flex rounded-full bg-moss-black px-5 py-3 text-sm font-extrabold text-cream transition hover:bg-moss-dark"
          href="/ask-the-owl/dictionary/"
        >
          Open the Dictionary
        </a>
      </article>
      <article
        class="rounded-lg border border-honey/25 bg-moss-black p-6 text-cream shadow-sm"
      >
        <p
          class="text-sm font-extrabold uppercase tracking-[0.16em] text-honey-bright"
        >
          Shortcut Fox
        </p>
        <h3 class="mt-3 text-3xl font-black text-cream">Shortcut Fox</h3>
        <p class="mt-4 text-base leading-7 text-cream/76">
          A field guide to cheap promises, black-box SEO, link schemes,
          reporting theater, and vendor lock-in.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {
            foxTraps.map((term) => (
              <span class="rounded-full border border-honey/20 bg-black/24 px-3 py-1.5 text-sm font-semibold text-cream/82">
                {term}
              </span>
            ))
          }
        </div>
        <a
          class="mt-7 inline-flex rounded-full bg-honey px-5 py-3 text-sm font-extrabold text-moss-black transition hover:bg-honey-bright"
          href="/bad-seo-field-guide/"
        >
          Open the Field Guide
        </a>
      </article>
    </div>
  </div>
</section>

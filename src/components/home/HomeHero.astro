---
import HiveDiagram from "./HiveDiagram.astro";
---

<section class="relative isolate overflow-hidden bg-[#080907] text-cream">
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_15%_15%,rgba(212,160,67,0.22),transparent_28%),radial-gradient(circle_at_85%_18%,rgba(197,106,74,0.14),transparent_24%),linear-gradient(180deg,#080907_0%,#10120f_58%,#171a14_100%)]"
  >
  </div>
  <div
    class="mx-auto grid max-w-7xl gap-12 px-4 py-16 sm:px-6 md:py-24 lg:grid-cols-[0.95fr_1.05fr] lg:items-center"
  >
    <div>
      <p
        class="text-sm font-extrabold uppercase tracking-[0.24em] text-honey-bright"
      >
        Boho Digital
      </p>
      <h1
        class="mt-5 max-w-4xl text-5xl font-black leading-[0.95] tracking-normal text-cream md:text-7xl"
      >
        SEO, websites, and growth systems without the agency fog.
      </h1>
      <p class="mt-6 max-w-3xl text-xl leading-8 text-cream/82">
        Boho Digital is a lean, tech-enabled growth studio for organic search,
        website systems, analytics, provider transfers, monthly support, and
        urgent digital cleanup.
      </p>
      <p
        class="mt-5 max-w-3xl border-l-2 border-honey pl-4 text-base leading-7 text-cream/78"
      >
        Internal systems, automation-assisted workflows, and low overhead help
        us move fast without making you pay for agency bloat.
      </p>
      <p
        class="mt-4 max-w-3xl text-sm font-semibold uppercase tracking-[0.14em] text-honey-bright"
      >
        No guaranteed-ranking spells. No mystery dashboards. No vendor lock-in.
        Just useful work, clear priorities, and receipts.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a class="btn-primary" href="/contact/">Get a Growth Audit</a>
        <a
          class="btn border-honey/45 bg-transparent text-cream hover:border-honey hover:bg-honey/10 hover:text-cream"
          href="/services/monthly-growth-retainer/"
        >
          See Monthly Support
        </a>
        <a
          class="btn border-terracotta/60 bg-terracotta/10 text-cream hover:border-terracotta hover:bg-terracotta/20 hover:text-cream"
          href="/contact/"
        >
          Request Rush Support
        </a>
      </div>
    </div>
    <HiveDiagram />
  </div>
</section>

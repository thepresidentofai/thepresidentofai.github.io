---
import { services } from "../../data/services";
import HoneycombGrid from "../ui/HoneycombGrid.astro";
import HoneycombServiceCard from "../ui/HoneycombServiceCard.astro";
---
<section class="section section-band-mist">
  <div class="container">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">Honeycomb services</p>
      <h2>Services arranged like a living system.</h2>
      <p>
        Every service supports the rest. The point is not to sell the biggest package.
        It is to build the smallest useful system that still strengthens the whole
        forest.
      </p>
    </div>
    <HoneycombGrid>
      {services.map((service) => (
        <HoneycombServiceCard
          href={`/services/${service.slug}/`}
          eyebrow={service.cardEyebrow}
          title={service.title}
          description={service.description}
        />
      ))}
    </HoneycombGrid>
  </div>
</section>

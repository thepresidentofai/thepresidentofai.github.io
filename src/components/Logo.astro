---
import { SITE } from "astrowind:config";
---

<span class="flex items-center gap-3">
  <img
    src="/assets/brand/bee-logo-mark.svg"
    alt=""
    class="h-9 w-9 rounded-full bg-white/70 p-1 shadow-sm"
  />
  <span class="flex flex-col">
    <span class="text-lg font-bold leading-tight text-charcoal"
      >{SITE?.name}</span
    >
    <span class="text-xs font-medium uppercase tracking-[0.14em] text-moss"
      >Bohemian Digital Marketing & SEO</span
    >
  </span>
</span>

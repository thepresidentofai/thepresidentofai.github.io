---
import { dictionaryBySlug, getDictionaryEntryHref } from "~/data/dictionary";

interface Props {
  slugs: string[];
}

const { slugs } = Astro.props;

const entries = slugs.map((slug) => {
  const entry = dictionaryBySlug[slug];
  if (!entry) {
    throw new Error(`Unknown related dictionary term slug: ${slug}`);
  }
  return entry;
});
---

{
  entries.length > 0 && (
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {entries.map((entry) => (
        <a
          class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm transition hover:-translate-y-0.5"
          href={getDictionaryEntryHref(entry.slug)}
        >
          <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
            {entry.category}
          </p>
          <h3 class="mt-3 text-xl font-bold text-charcoal">{entry.term}</h3>
          <p class="mt-3 text-muted">{entry.shortDefinition}</p>
        </a>
      ))}
    </div>
  )
}

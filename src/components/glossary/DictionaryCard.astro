---
import Button from "~/components/ui/Button.astro";
import {
  getDictionaryEntryHref,
  type DictionaryEntry,
} from "~/data/dictionary";

interface Props {
  entry: DictionaryEntry;
}

const { entry } = Astro.props;
---

<article class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm">
  <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
    {entry.category}
  </p>
  <h3 class="mt-3 text-2xl font-bold text-charcoal">{entry.term}</h3>
  <p class="mt-3 text-muted">{entry.shortDefinition}</p>
  <div class="mt-5">
    <Button href={getDictionaryEntryHref(entry.slug)} variant="secondary"
      >Read the Owl entry</Button
    >
  </div>
</article>

---
import GlossaryTerm from "~/components/glossary/GlossaryTerm.astro";
import { dictionaryBySlug } from "~/data/dictionary";

interface Props {
  text: string;
}

interface TextPart {
  type: "text";
  value: string;
}

interface TermPart {
  type: "term";
  slug: string;
  label?: string;
}

const { text } = Astro.props;
const parts: Array<TextPart | TermPart> = [];
const markerPattern = /\[\[([a-z0-9-]+)(?:\|([^\]]+))?\]\]/g;
let lastIndex = 0;
let match: RegExpExecArray | null;

while ((match = markerPattern.exec(text)) !== null) {
  if (match.index > lastIndex) {
    parts.push({ type: "text", value: text.slice(lastIndex, match.index) });
  }

  const slug = match[1];
  const label = match[2];

  if (!dictionaryBySlug[slug]) {
    throw new Error(`Unknown glossary term slug in text: ${slug}`);
  }

  parts.push({ type: "term", slug, label });
  lastIndex = markerPattern.lastIndex;
}

if (lastIndex < text.length) {
  parts.push({ type: "text", value: text.slice(lastIndex) });
}
---

<span class="glossary-text">
  {
    parts.map((part) =>
      part.type === "term" ? (
        <GlossaryTerm slug={part.slug} label={part.label} />
      ) : (
        part.value
      ),
    )
  }
</span>

---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(212 160 67);
    --aw-color-secondary: rgb(47 58 45);
    --aw-color-accent: rgb(197 106 74);

    --aw-color-text-heading: rgb(31 39 30);
    --aw-color-text-default: rgb(43 43 43);
    --aw-color-text-muted: rgb(43 43 43 / 72%);
    --aw-color-bg-page: rgb(247 243 236);
    --aw-color-bg-page-dark: rgb(31 39 30);

    ::selection {
      background-color: rgb(232 184 79 / 70%);
      color: rgb(31 39 30);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(232 184 79);
    --aw-color-secondary: rgb(138 160 138);
    --aw-color-accent: rgb(197 106 74);

    --aw-color-text-heading: rgb(247 243 236);
    --aw-color-text-default: rgb(247 243 236);
    --aw-color-text-muted: rgb(247 243 236 / 72%);
    --aw-color-bg-page: rgb(31 39 30);

    ::selection {
      background-color: rgb(212 160 67 / 45%);
      color: rgb(247 243 236);
    }
  }
</style>

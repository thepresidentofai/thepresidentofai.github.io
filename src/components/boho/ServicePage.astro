---
import Layout from "~/layouts/PageLayout.astro";
import HeroText from "~/components/widgets/HeroText.astro";
import CallToAction from "~/components/widgets/CallToAction.astro";
import WidgetWrapper from "~/components/ui/WidgetWrapper.astro";
import Headline from "~/components/ui/Headline.astro";
import Button from "~/components/ui/Button.astro";
import {
  getDictionaryTermHref,
  getServiceCardBySlug,
  type ServicePageDetail,
} from "~/data/boho";

interface ResourceCard {
  title: string;
  description: string;
  href: string;
}

interface Props {
  page: ServicePageDetail;
}

const { page } = Astro.props;

const metadata = {
  title: page.title,
  description: page.metadataDescription,
};

const relatedServices = page.relatedServiceSlugs
  .map((slug) => getServiceCardBySlug(slug))
  .filter((service): service is NonNullable<typeof service> => Boolean(service))
  .map((service) => ({
    title: service.title,
    description: service.description,
    href: service.href ?? "/services/",
  }));

const resourceCards: ResourceCard[] = [
  {
    title: "Services overview",
    description:
      "See the full service map and choose the smallest useful next step.",
    href: "/services/",
  },
  {
    title: "Pricing",
    description:
      "Use the current planning ranges as a grounded starting point.",
    href: "/pricing/",
  },
  {
    title: "Owl Dictionary",
    description:
      "Translate the terms that usually make search work sound more mysterious than it is.",
    href: "/ask-the-owl/dictionary/",
  },
];

if (page.includeFieldGuide) {
  resourceCards.push({
    title: "Bad SEO Field Guide",
    description:
      "Spot the fox traps before they cost you more time, money, or ownership.",
    href: "/bad-seo-field-guide/",
  });
}
---

<Layout metadata={metadata}>
  <HeroText
    tagline={page.title}
    title={page.heroTitle}
    subtitle={page.heroSubtitle}
    callToAction={{ text: page.primaryCtaText, href: "/contact/" }}
    callToAction2={{
      text: page.secondaryCta.text,
      href: page.secondaryCta.href,
    }}
  />

  {
    page.planningRange && (
      <WidgetWrapper containerClass="pt-0 md:pt-0 lg:pt-0">
        <div class="mx-auto max-w-3xl rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
            {page.planningRange.label}
          </p>
          <p class="mt-3 text-lg text-muted">
            {page.planningRange.description}
          </p>
        </div>
      </WidgetWrapper>
    )
  }

  <WidgetWrapper>
    <Headline
      title="What this fixes"
      subtitle="Start with the problem you can already name instead of buying a vague bundle and hoping the dashboard gets prettier."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        page.fixes.map((item) => (
          <article class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm">
            <p class="text-muted">{item}</p>
          </article>
        ))
      }
    </div>
  </WidgetWrapper>

  <WidgetWrapper>
    <Headline
      title="What Boho does"
      subtitle="The work should leave a readable trail, not a cloud of screenshots and implied expertise."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        page.whatBohoDoes.map((item, index) => (
          <article class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
              Step {index + 1}
            </p>
            <p class="mt-3 text-muted">{item}</p>
          </article>
        ))
      }
    </div>
  </WidgetWrapper>

  <WidgetWrapper>
    <Headline
      title="What you get"
      subtitle="Clear artifacts, cleaner decisions, and a next-step sequence you can actually use."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        page.whatYouGet.map((item) => (
          <article class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm">
            <p class="font-semibold text-charcoal">{item}</p>
          </article>
        ))
      }
    </div>
  </WidgetWrapper>

  <WidgetWrapper>
    <Headline
      title="What we will not pretend"
      subtitle="Honest growth work should be legible before it tries to be impressive."
    />
    <div class="mt-10 grid gap-4 xl:grid-cols-[1.35fr_1fr_1fr]">
      <article
        class="rounded-3xl border border-terracotta/20 bg-white/90 p-6 shadow-sm shadow-terracotta/5"
      >
        <p
          class="text-sm font-semibold uppercase tracking-[0.12em] text-terracotta-dark"
        >
          No fog machines
        </p>
        <p class="mt-3 text-muted">{page.honesty}</p>
      </article>
      <article
        class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm"
      >
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
          Good fit
        </p>
        <p class="mt-3 text-muted">{page.goodFit}</p>
      </article>
      <article
        class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm"
      >
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
          Not a fit
        </p>
        <p class="mt-3 text-muted">{page.notFit}</p>
      </article>
    </div>
  </WidgetWrapper>

  <WidgetWrapper>
    <Headline
      title="Related Owl terms"
      subtitle="Use the dictionary when you need the plain-English version, then follow the related pages for the next useful layer."
    />
    <div class="mt-10 flex flex-wrap gap-3">
      {
        page.owlTerms.map((term) => (
          <Button href={getDictionaryTermHref(term)} variant="secondary">
            {term}
          </Button>
        ))
      }
    </div>

    <div class="mt-10 grid gap-4 lg:grid-cols-2">
      {
        relatedServices.map((service) => (
          <a
            class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm transition hover:-translate-y-0.5"
            href={service.href}
          >
            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
              Related service
            </p>
            <h3 class="mt-3 text-xl font-bold text-charcoal">
              {service.title}
            </h3>
            <p class="mt-3 text-muted">{service.description}</p>
          </a>
        ))
      }
      {
        resourceCards.map((resource) => (
          <a
            class="rounded-3xl border border-moss/15 bg-white/90 p-6 shadow-sm transition hover:-translate-y-0.5"
            href={resource.href}
          >
            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-moss">
              Useful next path
            </p>
            <h3 class="mt-3 text-xl font-bold text-charcoal">
              {resource.title}
            </h3>
            <p class="mt-3 text-muted">{resource.description}</p>
          </a>
        ))
      }
    </div>
  </WidgetWrapper>

  <CallToAction
    title={page.finalCtaTitle}
    subtitle={page.finalCtaBody}
    actions={[
      {
        variant: "primary",
        text: page.finalCtaButton,
        href: "/contact/",
      },
    ]}
  />
</Layout>

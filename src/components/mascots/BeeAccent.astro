---
interface Props {
  decorative?: boolean;
  alt?: string;
  className?: string;
}

const {
  decorative = true,
  alt = "Bee accent",
  className = ""
} = Astro.props;
---
<img
  class:list={["mascot-accent", "mascot-bee", className]}
  src="/assets/mascots/bee-tiny.svg"
  alt={decorative ? "" : alt}
  aria-hidden={decorative ? "true" : undefined}
  width="72"
  height="72"
  loading="lazy"
  decoding="async"
/>
